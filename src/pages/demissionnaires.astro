---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Button from '../components/ui/Button.astro';
import '../styles/style.css';
---

<Layout title="Élèves démissionnaires | Internat">
    <Header />
    <main class="main-content">
        <header class="page-context mb-xl">
            <h1 class="page-title-sm">Élèves Démissionnaires</h1>
            <p class="text-muted">Archive des élèves ayant quitté l'internat</p>
        </header>

        <div class="controls-bar mb-xl">
            <div class="search-group">
                <div class="form-group">
                    <label for="dem_search">Recherche</label>
                    <input type="text" id="dem_search" placeholder="Nom, prénom..." 
                        style="padding:12px 16px; border:1px solid var(--border-color); border-radius:var(--radius-lg); outline:none; width:250px;">
                </div>
            </div>
            <Button href="/eleves" variant="secondary">Retourner à l'annuaire</Button>
        </div>

        <div class="card">
            <div class="table-container">
                <table id="tableDemissionnaires">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Prénom</th>
                            <th>Genre</th>
                            <th>Adresse</th>
                            <th>Date Sortie</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        <tr>
                            <td colspan="6" class="text-center text-muted">Chargement...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div id="noResults" class="text-center p-xl" style="display:none;"> Aucun élève démissionnaire trouvé. </div>
        </div>
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        chargerDemissionnaires();

        document.getElementById('dem_search')?.addEventListener('input', (e) => {
            const term = (e.target as HTMLInputElement).value.toLowerCase();
            const rows = document.querySelectorAll('#tableBody tr');
            rows.forEach(row => {
                const text = row.textContent?.toLowerCase() || '';
                (row as HTMLElement).style.display = text.includes(term) ? '' : 'none';
            });
        });
    });

    async function chargerDemissionnaires() {
        try {
            const response = await fetch('/api/demissionnaires');
            if (!response.ok) throw new Error("Erreur réseau");
            
            const data = await response.json();
            afficherTableau(data);
        } catch (error) {
            console.error("Erreur chargement démissionnaires:", error);
            const body = document.getElementById('tableBody');
            if(body) body.innerHTML = '<tr><td colspan="6" class="text-center text-danger">Erreur de connexion</td></tr>';
        }
    }

    function afficherTableau(data: any[]) {
        const b = document.getElementById('tableBody');
        const noResults = document.getElementById('noResults');
        if (!b || !noResults) return;
        b.innerHTML = '';

        if (data.length === 0) {
            noResults.style.display = 'block';
            b.parentElement!.parentElement!.style.display = 'none';
            return;
        }

        noResults.style.display = 'none';
        b.innerHTML = data.map(e => `
            <tr>
                <td class="font-bold">${e.nom || '-'}</td>
                <td>${e.prenom || '-'}</td>
                <td><span class="status-badge">${e.genre || '-'}</span></td>
                <td>${e.adresse || '-'}</td>
                <td>${e.date_sortie ? new Date(e.date_sortie).toLocaleDateString() : '-'}</td>
                <td>
                    <button class="btn btn-secondary btn-sm btn-restore" data-id="${e.id}">Restaurer</button>
                </td>
            </tr>
        `).join('');

        b.querySelectorAll('.btn-restore').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                const id = target.dataset.id;
                if(id) restaurerEleve(id);
            });
        });
    }

    async function restaurerEleve(id: string) {
        if (!confirm("Voulez-vous restaurer cet élève ?")) return;
        try {
            const response = await fetch('/api/demissionnaires/restore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            if (response.ok) {
                alert("Élève restauré !");
                chargerDemissionnaires();
            } else {
                const err = await response.json();
                alert("Erreur: " + err.error);
            }
        } catch (err) {
            console.error("Erreur restauration:", err);
        }
    }
</script>

<style>
    .font-bold {
        font-weight: 700;
        color: var(--primary-dark);
    }
</style>
