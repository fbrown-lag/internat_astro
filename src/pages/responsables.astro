---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Button from '../components/ui/Button.astro';
import '../styles/style.css';
---

<Layout title="Gestion des Responsables | Internat">
    <Header />

    <main class="main-content">
        <header class="page-context mb-xl">
            <h1 class="page-title-sm">Gestion des Responsables</h1>
            <p class="text-muted">Annuaire et contacts des responsables légaux</p>
        </header>

        <div class="controls-bar mb-xl">
            <div class="search-group">
                <div class="form-group">
                    <label for="resp_search">Recherche</label>
                    <input type="text" id="resp_search" placeholder="Nom, téléphone..." 
                        style="padding:12px 16px; border:1px solid var(--border-color); border-radius:var(--radius-lg); outline:none; width:250px;">
                </div>
            </div>
            <div class="flex-grow"></div>
            <Button id="btnOpenAddResp" variant="primary">+ Nouveau Responsable</Button>
        </div>

        <div class="table-container">
            <table class="luxury-table">
                <thead>
                    <tr>
                        <th>NOM</th>
                        <th>PRÉNOM</th>
                        <th>TÉLÉPHONE</th>
                        <th>ADRESSE</th>
                        <th style="width: 150px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody id="responsablesTableBody">
                    <tr><td colspan="5" style="text-align: center;">Chargement...</td></tr>
                </tbody>
            </table>
        </div>
    </main>

    <!-- MODAL ADD/EDIT RESPONSABLE -->
    <div id="modalResponsable" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:2000; justify-content:center; align-items:center;">
        <div style="background: var(--bg-surface); padding:30px; border:1px solid var(--border-color); border-radius:var(--radius-xl); width:500px; box-shadow: var(--shadow-lg);">
            <h3 id="respModalTitle" style="color:var(--text-main); margin-top:0; font-size:1.3rem; font-weight:700;">Nouveau Responsable</h3>
            <input type="hidden" id="edit_resp_id">
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <div style="display:flex; gap:10px;">
                    <div style="flex:1;">
                        <label style="color:var(--text-main); font-size:0.875rem; font-weight:600; display:block; margin-bottom:5px;">NOM *</label>
                        <input type="text" id="resp_nom" style="width:100%; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-main); padding:10px; border-radius:var(--radius-md); outline:none;">
                    </div>
                    <div style="flex:1;">
                        <label style="color:var(--text-main); font-size:0.875rem; font-weight:600; display:block; margin-bottom:5px;">PRÉNOM</label>
                        <input type="text" id="resp_prenom" style="width:100%; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-main); padding:10px; border-radius:var(--radius-md); outline:none;">
                    </div>
                </div>
                <div>
                    <label style="color:var(--text-main); font-size:0.875rem; font-weight:600; display:block; margin-bottom:5px;">TÉLÉPHONE</label>
                    <input type="text" id="resp_tel" style="width:100%; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-main); padding:10px; border-radius:var(--radius-md); outline:none;">
                </div>
                <div>
                    <label style="color:var(--text-main); font-size:0.875rem; font-weight:600; display:block; margin-bottom:5px;">ADRESSE</label>
                    <textarea id="resp_adresse" rows="3" style="width:100%; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-main); padding:10px; border-radius:var(--radius-md); outline:none; resize:vertical;"></textarea>
                </div>
                <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:10px;">
                    <button id="btnCancelModal" class="btn btn-ghost">Annuler</button>
                    <button id="btnSaveResp" class="btn btn-primary">Enregistrer</button>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        chargerResponsables();
        
        document.getElementById('btnOpenAddResp')?.addEventListener('click', () => ouvrirModal());
        document.getElementById('btnCancelModal')?.addEventListener('click', fermerModal);
        document.getElementById('btnSaveResp')?.addEventListener('click', sauvegarderResponsable);
        
        document.getElementById('resp_search')?.addEventListener('input', (e) => {
            const term = (e.target as HTMLInputElement).value.toLowerCase();
            const rows = document.querySelectorAll('#responsablesTableBody tr');
            rows.forEach(row => {
                const text = row.textContent?.toLowerCase() || '';
                (row as HTMLElement).style.display = text.includes(term) ? '' : 'none';
            });
        });
    });

    async function chargerResponsables() {
        try {
            const res = await fetch('/api/responsables');
            const data = await res.json();
            const tbody = document.getElementById('responsablesTableBody');
            if(!tbody) return;

            tbody.innerHTML = '';
            if(data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">Aucun responsable enregistré.</td></tr>';
                return;
            }

            data.forEach((r: any) => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td style="font-weight:bold;">${r.nom.toUpperCase()}</td>
                    <td>${r.prenom || '-'}</td>
                    <td>${r.telephone || '-'}</td>
                    <td style="font-size: 0.85rem; color: var(--text-muted);">${r.adresse || '-'}</td>
                    <td style="text-align:center;">
                        <button class="btn-edit" style="color:var(--primary); background:none; border:none; cursor:pointer; font-size:1.2rem; margin-right:15px;">✏️</button>
                        <button class="btn-delete" style="color:red; background:none; border:none; cursor:pointer; font-size:1.2rem;">✕</button>
                    </td>
                `;
                
                row.querySelector('.btn-edit')?.addEventListener('click', () => ouvrirModal(r));
                row.querySelector('.btn-delete')?.addEventListener('click', () => supprimerResponsable(r.id));
                
                tbody.appendChild(row);
            });
        } catch(err) { console.error(err); }
    }

    function ouvrirModal(resp: any = null) {
        const modal = document.getElementById('modalResponsable');
        const title = document.getElementById('respModalTitle');
        const idInput = document.getElementById('edit_resp_id') as HTMLInputElement;
        const nomInput = document.getElementById('resp_nom') as HTMLInputElement;
        const prenomInput = document.getElementById('resp_prenom') as HTMLInputElement;
        const telInput = document.getElementById('resp_tel') as HTMLInputElement;
        const adresseInput = document.getElementById('resp_adresse') as HTMLTextAreaElement;

        if (resp) {
            title!.textContent = "Modifier le Responsable";
            idInput.value = resp.id;
            nomInput.value = resp.nom;
            prenomInput.value = resp.prenom || '';
            telInput.value = resp.telephone || '';
            adresseInput.value = resp.adresse || '';
        } else {
            title!.textContent = "Nouveau Responsable";
            idInput.value = '';
            nomInput.value = '';
            prenomInput.value = '';
            telInput.value = '';
            adresseInput.value = '';
        }
        modal!.style.display = 'flex';
    }

    function fermerModal() {
        document.getElementById('modalResponsable')!.style.display = 'none';
    }

    async function sauvegarderResponsable() {
        const id = (document.getElementById('edit_resp_id') as HTMLInputElement).value;
        const nom = (document.getElementById('resp_nom') as HTMLInputElement).value;
        const prenom = (document.getElementById('resp_prenom') as HTMLInputElement).value;
        const telephone = (document.getElementById('resp_tel') as HTMLInputElement).value;
        const adresse = (document.getElementById('resp_adresse') as HTMLTextAreaElement).value;

        if (!nom) return alert("Le nom est obligatoire");

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/responsables/${id}` : '/api/responsables';

        try {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nom, prenom, telephone, adresse })
            });

            if (res.ok) {
                fermerModal();
                chargerResponsables();
            } else {
                const err = await res.json();
                alert(err.error || "Erreur lors de l'enregistrement");
            }
        } catch(err) { console.error(err); }
    }

    async function supprimerResponsable(id: string) {
        if(!confirm("Supprimer ce responsable ?")) return;
        try {
            const res = await fetch(`/api/responsables/${id}`, { method: 'DELETE' });
            if(res.ok) chargerResponsables();
            else {
                const err = await res.json();
                alert(err.error || "Erreur lors de la suppression");
            }
        } catch(err) { console.error(err); }
    }
</script>
