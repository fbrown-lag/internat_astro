---
interface Props {
	id: string;
	label: string;
	value?: string | number;
	type?: "text" | "number" | "time" | "date" | "email" | "password";
	placeholder?: string;
	required?: boolean;
	class?: string;
	style?: string;
	autocomplete?: string; // Ajout pour corriger l'erreur TS(2322)
}

const {
	id,
	label,
	value,
	type = "text",
	placeholder,
	required = false,
	class: className = "",
	style,
	autocomplete,
} = Astro.props;
---

<div class:list={["form-group", className]} style={style}>
	<label for={id}>{label}</label>
	<div class="input-wrapper">
		<input
			id={id}
			name={id}
			type={type}
			value={value}
			placeholder={placeholder}
			required={required}
			autocomplete={autocomplete}
		/>
	</div>
</div>

<style>
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem; /* Équivalent var(--space-xs) */
		text-align: left;
		width: 100%;
	}

	label {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--secondary);
		display: block;
	}

	.input-wrapper input {
		width: 100%;
		padding: 12px 16px;
		border: 1px solid var(--border-color);
		border-radius: var(--radius-lg);
		font-size: 0.95rem;
		background: var(--bg-surface);
		color: var(--text-main);
		transition: all 0.2s ease; /* Équivalent var(--transition-base) */
		outline: none;
	}

	.input-wrapper input:focus {
		border-color: var(
			--primary
		); /* Ou var(--text-main) selon votre charte */
		box-shadow: 0 0 0 2px rgba(var(--primary-rgb), 0.1);
	}

	input::placeholder {
		color: var(--text-muted);
		opacity: 0.7;
	}

	/* Style spécifique pour le type date pour uniformiser le rendu */
	input[type="date"] {
		font-family: inherit;
	}
</style>
